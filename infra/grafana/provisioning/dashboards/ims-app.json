{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "IMS Modular Monolith — Application Metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{job=\"ims-app\"}[1m])",
          "legendFormat": "{{method}} {{route}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Request Latency P95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_server_request_duration_seconds_bucket{job=\"ims-app\"}[5m])) * 1000",
          "legendFormat": "P95 {{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_server_request_duration_seconds_count{job=\"ims-app\",status_code=~\"5..\"}[1m])",
          "legendFormat": "5xx {{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "GC Heap Size (MB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "dotnet_gc_heap_size_bytes{job=\"ims-app\"} / 1024 / 1024",
          "legendFormat": "Heap {{generation}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active DB Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"ims_db\"}",
          "legendFormat": "PostgreSQL connections"
        }
      ]
    },
    {
      "id": 6,
      "title": "RabbitMQ Messages Ready",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_ready",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Outbox Pending Messages",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(outbox_messages_pending_total{job=\"ims-app\"})",
          "legendFormat": "Pending"
        }
      ]
    },
    {
      "id": 8,
      "title": "Redis Memory (MB)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "Used MB"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ims", "dotnet", "api"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "title": "IMS Modular — Application Metrics",
  "uid": "ims-app-metrics",
  "version": 1
}

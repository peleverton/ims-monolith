# =============================================================
# .env.example — IMS Modular Monolith
# =============================================================
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
#
# ATENÇÃO: nunca versionar o .env com credenciais reais.
# =============================================================

# ── App ──────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
APP_PORT=8080

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=ims_db
POSTGRES_USER=ims
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PORT=6379

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_USER=ims
RABBITMQ_PASSWORD=change_me_rabbit
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_jwt_secret_min_32_chars_long!!
JWT_ISSUER=IMS.Modular
JWT_AUDIENCE=IMS.Client

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_grafana
GRAFANA_PORT=3000

# ── Jaeger (Observability — US-027) ──────────────────────────
JAEGER_UI_PORT=16686

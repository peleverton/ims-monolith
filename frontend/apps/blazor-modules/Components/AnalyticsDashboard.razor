<MudThemeProvider />
<MudSnackbarProvider />

@if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Class="pa-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        <MudText Class="mt-2 mud-text-secondary">Carregando analytics...</MudText>
    </MudStack>
}
else if (_summary is null)
{
    <MudAlert Severity="Severity.Warning" Class="ma-4">
        Não foi possível carregar os dados. Verifique sua conexão.
    </MudAlert>
}
else
{
    <MudPaper Class="pa-4" Elevation="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
            <MudText Typo="Typo.h6">Analytics Dashboard</MudText>
            <MudTooltip Text="Atualizar dados">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Primary"
                               OnClick="LoadData" />
            </MudTooltip>
        </MudStack>

        <!-- KPI Cards -->
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3">
                <KpiCard Title="Total de Issues" Value="@_summary.TotalIssues.ToString()" Icon="@Icons.Material.Filled.BugReport" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <KpiCard Title="Issues Abertas" Value="@_summary.OpenIssues.ToString()" Icon="@Icons.Material.Filled.Inbox" Color="Color.Warning" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <KpiCard Title="Em Progresso" Value="@_summary.InProgressIssues.ToString()" Icon="@Icons.Material.Filled.Autorenew" Color="Color.Info" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <KpiCard Title="Itens em Estoque" Value="@_summary.TotalInventoryItems.ToString()" Icon="@Icons.Material.Filled.Inventory2" Color="Color.Success" />
            </MudItem>
        </MudGrid>

        <!-- Gráficos -->
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Issues por dia (últimos 30 dias)</MudText>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@_lineChartSeries"
                              XAxisLabels="@_lineLabels"
                              Height="220"
                              ChartOptions="_lineOptions" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Issues por status</MudText>
                    <MudChart ChartType="ChartType.Donut"
                              InputData="@_donutData"
                              InputLabels="@_donutLabels"
                              Height="220" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12">
                <MudPaper Class="pa-4" Outlined="true">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Issues por prioridade</MudText>
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@_barSeries"
                              XAxisLabels="@_barLabels"
                              Height="200"
                              ChartOptions="_barOptions" />
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

{
  "name": "next-shell",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "blazor:build": "bash ../../../scripts/build-blazor.sh",
    "predev": "npm run blazor:build",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run __tests__/contracts",
    "generate:api": "openapi-typescript http://localhost:8080/swagger/v1/swagger.json -o lib/api/generated.ts",
    "generate:api:ci": "openapi-typescript $IMS_API_SWAGGER_URL -o lib/api/generated.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@microsoft/signalr": "^10.0.0",
    "@tanstack/react-query": "^5.99.0",
    "clsx": "^2.1.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.13.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.3.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.0.2",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}

# =============================================================
# .env — IMS Modular Monolith (desenvolvimento local)
# =============================================================
# Gerado automaticamente para dev local. NÃO versionar este arquivo.
# =============================================================

# ── App ──────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
APP_PORT=8080

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=ims_db
POSTGRES_USER=ims
POSTGRES_PASSWORD=ims_dev_pass
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PORT=6379

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_USER=ims
RABBITMQ_PASSWORD=ims_dev_pass
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY=ims_dev_jwt_secret_min_32_chars_long!!
JWT_ISSUER=IMS.Modular
JWT_AUDIENCE=IMS.Client

# ── Frontend ─────────────────────────────────────────────────
NEXTAUTH_SECRET=ims_dev_nextauth_secret_32chars!!
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3001

# ── Jaeger ───────────────────────────────────────────────────
JAEGER_UI_PORT=16686
